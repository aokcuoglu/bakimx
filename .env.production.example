# ──────────────────────────────────────────────
# PostgreSQL (internal via Docker network)
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://bakimx:CHANGE_ME_STRONG_PASSWORD@db:5432/bakimx?schema=public"
DIRECT_URL="postgresql://bakimx:CHANGE_ME_STRONG_PASSWORD@db:5432/bakimx?schema=public"
POSTGRES_USER=bakimx
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=bakimx

# ──────────────────────────────────────────────
# Next.js
# ──────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_TO_RANDOM_32_PLUS_CHARS
APP_URL=https://app.bakimx.com
NODE_ENV=production

# ──────────────────────────────────────────────
# Admin console (/admin)
# ──────────────────────────────────────────────
# Comma-separated e-mails allowed into the founder admin console.
# If UNSET, /admin returns 404 for EVERYONE (requireAdmin → notFound).
# Must contain the e-mail you log in with. Never use the public demo account here.
ADMIN_EMAILS=alpkaan@bakimx.com,emre@bakimx.com,hey@bakimx.com

# ──────────────────────────────────────────────
# Backups — optional offsite copy (rclone)
# ──────────────────────────────────────────────
# After `rclone config`, set a remote so /opt/bakimx/backup.sh copies dumps off-box
# (otherwise backups only live on the VPS disk — they die with it). e.g. an R2/B2 bucket:
# BAKIMX_RCLONE_REMOTE=r2:bakimx-backups

# ──────────────────────────────────────────────
# Storage — Cloudflare R2 (S3-compatible)
# ──────────────────────────────────────────────
STORAGE_PROVIDER=s3
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
S3_BUCKET=bakimx-media
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_DOMAIN=pub-YOUR_HASH.r2.dev

# ──────────────────────────────────────────────
# OCR Provider — mock, deepseek, openai, or tesseract
# ──────────────────────────────────────────────
OCR_PROVIDER=mock
# DEEPSEEK_API_KEY=
# DEEPSEEK_OCR_MODEL=deepseek-chat
# OPENAI_API_KEY=
# OPENAI_OCR_MODEL=gpt-4o

# ──────────────────────────────────────────────
# AI Service Advisor — mock, openai, or deepseek
# ──────────────────────────────────────────────
AI_PROVIDER=mock
# AI_MODEL=

# ──────────────────────────────────────────────
# Communication Providers
# ──────────────────────────────────────────────
SMS_PROVIDER=mock
# NETGSM_USERCODE=
# NETGSM_PASSWORD=
# NETGSM_SENDER=BAKIMX
# NETGSM_API_URL=https://api.netgsm.com.tr/sms/send/get

WHATSAPP_PROVIDER=mock
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0

EMAIL_PROVIDER=gmail
GMAIL_USER=hey@bakimx.com
GMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=BakimX
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=no-reply@bakimx.com
# RESEND_FROM_NAME=BakimX
# RESEND_API_URL=https://api.resend.com/emails

# ──────────────────────────────────────────────
# Calendar Provider
# ──────────────────────────────────────────────
CALENDAR_PROVIDER=mock

# ──────────────────────────────────────────────
# Cron / Scheduled Jobs
# ──────────────────────────────────────────────
# CRON_SECRET=your-random-secret-string