# ──────────────────────────────────────────────
# Local Development (docker-compose.local.yml)
# ──────────────────────────────────────────────
# Run: docker compose -f docker-compose.local.yml up -d
# Then copy the local block below into .env.local

# --- Local PostgreSQL (OrbStack / Docker) ---
DATABASE_URL="postgresql://bakimx:bakimx@localhost:5432/bakimx"
DIRECT_URL="postgresql://bakimx:bakimx@localhost:5432/bakimx"

# --- Local MinIO (S3-compatible, OrbStack / Docker) ---
STORAGE_PROVIDER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=bakimx
S3_SECRET_ACCESS_KEY=bakimx-dev-secret
S3_BUCKET=bakimx-media
S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_DOMAIN is omitted locally — presigned URLs are used instead

# ──────────────────────────────────────────────
# Remote / Supabase (alternative to local)
# ──────────────────────────────────────────────
# DATABASE_URL="postgresql://postgres.USER:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.USER:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars"
# Public app origin — e-posta linkleri (/login, /admin) ve portal linkleri bundan üretilir.
APP_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# Storage Provider
# ──────────────────────────────────────────────
# mock  — in-memory, files lost on restart (default, zero setup)
# s3    — MinIO (local) or Cloudflare R2 (production)
# STORAGE_PROVIDER=mock

# Cloudflare R2 (required when STORAGE_PROVIDER=s3 in production)
# S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=your-r2-access-key-id
# S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
# S3_BUCKET=bakimx-media
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_DOMAIN=pub-YOUR_HASH.r2.dev

# ──────────────────────────────────────────────
# OCR Provider — mock (default), anthropic, or openai
# ──────────────────────────────────────────────
# When set to "mock" or empty, the system returns demo registration data.
# To use real OCR, set to "anthropic" (recommended) or "openai" and provide
# the corresponding API key. The ruhsat image is sent directly to a vision
# model, which returns all fields as structured JSON (no Tesseract step).
OCR_PROVIDER=mock

# OCR Model — override the default vision model for the selected provider.
# If not set, uses the provider default (anthropic → claude-haiku-4-5).
# Examples: claude-haiku-4-5, claude-sonnet-5, claude-opus-4-8 (anthropic); gpt-4o (openai)
# OCR_MODEL=

# Anthropic / Claude Vision OCR (requires OCR_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI OCR (requires OCR_PROVIDER=openai)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_OCR_MODEL=gpt-4o

# ──────────────────────────────────────────────
# AI Service Advisor Provider — mock (default), anthropic, or openai
# ──────────────────────────────────────────────
# When set to "mock" or empty, the system returns demo suggestions.
# To use real AI, set to "anthropic" (recommended) or "openai" and provide
# the corresponding API key. AI_MODEL is optional (defaults apply).
AI_PROVIDER=mock

# AI Model — override the default model for the selected provider.
# Examples: claude-haiku-4-5 (anthropic, default), gpt-4o-mini (openai, default)
# AI_MODEL=

# Anthropic / Claude AI Advisor (requires AI_PROVIDER=anthropic)
# Uses ANTHROPIC_API_KEY (shared with the ruhsat OCR vision provider)
# AI_MODEL=claude-haiku-4-5

# OpenAI AI Advisor (requires AI_PROVIDER=openai)
# Uses OPENAI_API_KEY (shared with OCR if OCR_PROVIDER=openai)
# AI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────
# Communication Providers
# ──────────────────────────────────────────────

# SMS Provider — mock (default) or netgsm
SMS_PROVIDER=mock

# Netgsm SMS (required when SMS_PROVIDER=netgsm)
# NETGSM_USERCODE=your-netgsm-usercode
# NETGSM_PASSWORD=your-netgsm-password
# NETGSM_SENDER=BAKIMX
# NETGSM_API_URL=https://api.netgsm.com.tr/sms/send/get

# WhatsApp Provider — mock (default) or business
WHATSAPP_PROVIDER=mock

# WhatsApp Business API (required when WHATSAPP_PROVIDER=business)
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_ACCESS_TOKEN=your-access-token
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# E-posta sağlayıcı: mock | gmail | resend
EMAIL_PROVIDER=mock

# Gmail SMTP (EMAIL_PROVIDER=gmail iken gerekli)
# GMAIL_USER=hey@bakimx.com
# GMAIL_APP_PASSWORD=            # Google App Password (16 hane, boşluksuz). 2-Step Verification açık olmalı.
# EMAIL_FROM_NAME=BakimX

# Resend Email (required when EMAIL_PROVIDER=resend)
# RESEND_API_KEY=your-resend-api-key
# RESEND_FROM_EMAIL=no-reply@bakimx.com
# RESEND_FROM_NAME=BakimX
# RESEND_API_URL=https://api.resend.com/emails

# ──────────────────────────────────────────────
# Cron / Scheduled Jobs
# ──────────────────────────────────────────────

# Secret for cron endpoint authentication (REQUIRED in ALL environments).
# The /api/cron/reminders endpoint returns 500 if this is unset and 401 if the
# Bearer token does not match — it is never publicly accessible.
# Set this to a long random string and send it as the Bearer token.
CRON_SECRET="change-me-to-a-long-random-string"

# ──────────────────────────────────────────────
# Calendar Provider
# ──────────────────────────────────────────────

# Calendar Provider — mock (default) or google
CALENDAR_PROVIDER=mock

# Google Calendar (required when CALENDAR_PROVIDER=google)
# GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# GOOGLE_CALENDAR_ACCESS_TOKEN=your-access-token
# GOOGLE_CALENDAR_API_URL=https://www.googleapis.com/calendar/v3
# --- Admin console (/admin) ---
# Comma-separated e-mails allowed to access the founder admin console.
# If unset, /admin returns 404 for everyone.
ADMIN_EMAILS=

# Optional: WhatsApp number (digits only, e.g. 905551112233) used by billing/
# locked-screen "İletişime geç" deep links. If unset, opens generic WhatsApp.
NEXT_PUBLIC_SUPPORT_WHATSAPP=

# ──────────────────────────────────────────────
# Billing (manual/havale checkout v1)
# ──────────────────────────────────────────────
# Shown on the checkout confirmation screen. No real card gateway yet.
BILLING_HAVALE_IBAN="TR00 0000 0000 0000 0000 0000 00"
BILLING_HAVALE_ACCOUNT_TITLE="BakımX Yazılım"
BILLING_HAVALE_BANK="Banka adı"
