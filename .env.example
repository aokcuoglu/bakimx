# PostgreSQL / Supabase — pooler mode
DATABASE_URL="postgresql://user:password@localhost:5432/bakimx"

# PostgreSQL / Supabase — direct mode (for Prisma migrations)
DIRECT_URL="postgresql://user:password@localhost:5432/bakimx"

SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars"
APP_URL="http://localhost:3000"

# Storage Provider — mock (default) or s3
STORAGE_PROVIDER=mock

# S3-compatible Storage — Cloudflare R2 (required when STORAGE_PROVIDER=s3)
# S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=your-r2-access-key-id
# S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
# S3_BUCKET=bakimx-media
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_DOMAIN=pub-YOUR_HASH.r2.dev

# OCR Provider — mock (default), deepseek, openai, or tesseract
# When set to "mock" or empty, the system returns demo registration data.
# To use real OCR, set to "deepseek", "openai", or "tesseract" and provide
# the corresponding API key and model (where applicable).
OCR_PROVIDER=mock

# OCR Model — override the default model for the selected provider.
# If not set, falls back to the provider-specific env var.
# Examples: gpt-4o, gpt-4o-mini (openai), deepseek-chat, deepseek-reasoner (deepseek)
# OCR_MODEL=

# DeepSeek OCR (requires OCR_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_OCR_MODEL=deepseek-chat

# OpenAI OCR (requires OCR_PROVIDER=openai)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_OCR_MODEL=gpt-4o

# Tesseract OCR (requires OCR_PROVIDER=tesseract)
# Local-only OCR using Tesseract.js — no API key needed.
# Accuracy is lower than DeepSeek/OpenAI; best used as a fallback.

# AI Service Advisor Provider — mock (default), openai, or deepseek
# When set to "mock" or empty, the system returns demo suggestions.
# To use real AI, set to "openai" or "deepseek" and provide
# the corresponding API key. AI_MODEL is optional (defaults apply).
AI_PROVIDER=mock

# AI Model — override the default model for the selected provider.
# Examples: gpt-4o-mini (openai, default), deepseek-chat (deepseek, default)
# AI_MODEL=

# OpenAI AI Advisor (requires AI_PROVIDER=openai)
# Uses OPENAI_API_KEY (shared with OCR if OCR_PROVIDER=openai)
# AI_MODEL=gpt-4o-mini

# DeepSeek AI Advisor (requires AI_PROVIDER=deepseek)
# Uses DEEPSEEK_API_KEY (shared with OCR if OCR_PROVIDER=deepseek)
# AI_MODEL=deepseek-chat

# ──────────────────────────────────────────────
# Communication Providers
# ──────────────────────────────────────────────

# SMS Provider — mock (default) or netgsm
SMS_PROVIDER=mock

# Netgsm SMS (required when SMS_PROVIDER=netgsm)
# NETGSM_USERCODE=your-netgsm-usercode
# NETGSM_PASSWORD=your-netgsm-password
# NETGSM_SENDER=BAKIMX
# NETGSM_API_URL=https://api.netgsm.com.tr/sms/send/get

# WhatsApp Provider — mock (default) or business
WHATSAPP_PROVIDER=mock

# WhatsApp Business API (required when WHATSAPP_PROVIDER=business)
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_ACCESS_TOKEN=your-access-token
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# Email Provider — mock (default) or resend
EMAIL_PROVIDER=mock

# Resend Email (required when EMAIL_PROVIDER=resend)
# RESEND_API_KEY=your-resend-api-key
# RESEND_FROM_EMAIL=no-reply@bakimx.com
# RESEND_FROM_NAME=BakimX
# RESEND_API_URL=https://api.resend.com/emails

# ──────────────────────────────────────────────
# Cron / Scheduled Jobs
# ──────────────────────────────────────────────

# Secret for cron endpoint authentication (required in production)
# Set this to a random string and use as Bearer token when calling /api/cron/reminders
# CRON_SECRET=your-random-secret-string

# ──────────────────────────────────────────────
# Calendar Provider
# ──────────────────────────────────────────────

# Calendar Provider — mock (default) or google
CALENDAR_PROVIDER=mock

# Google Calendar (required when CALENDAR_PROVIDER=google)
# GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# GOOGLE_CALENDAR_ACCESS_TOKEN=your-access-token
# GOOGLE_CALENDAR_API_URL=https://www.googleapis.com/calendar/v3