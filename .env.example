# PostgreSQL / Supabase — pooler mode (transaction, IPv4, port 6543)
DATABASE_URL="postgresql://user:password@localhost:5432/bakimx"

# PostgreSQL / Supabase — direct mode (port 5432, for Prisma migrations)
DIRECT_URL="postgresql://user:password@localhost:5432/bakimx"

SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars"
APP_URL="http://localhost:3000"

# Storage Provider — mock (default), supabase, or s3
STORAGE_PROVIDER=mock

# Supabase Storage (required when STORAGE_PROVIDER=supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_STORAGE_BUCKET=bakimx-media

# S3-compatible Storage (placeholder — not yet implemented)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=bakimx-media
# S3_FORCE_PATH_STYLE=false