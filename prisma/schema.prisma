generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workshop {
  id           String   @id @default(cuid())
  name         String
  phone        String
  city         String
  district     String?
  address      String
  email        String?
  website      String?
  logoUrl      String?
  taxNumber    String?
  taxOffice    String?
  invoiceTitle String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  settings     WorkshopSettings?
  users        User[]
  customers    Customer[]
  vehicles     Vehicle[]
  intakes      VehicleIntakeForm[]
  photos       VehiclePhoto[]
  damageMarks  DamageMark[]
  approvals    ApprovalRequest[]
  shareLinks   PublicShareLink[]
  timelineEvents IntakeTimelineEvent[]
  orders       ServiceOrder[]
  quotes       Quote[]
  quoteItems   QuoteItem[]
  appointments Appointment[]
  reminders    MaintenanceReminder[]
  auditLogs    AuditLog[]
  partStockItems PartStockItem[]
  stockMovements StockMovement[]
  suppliers     Supplier[]
  collections       CollectionPayment[]
  ocrLogs           OcrLog[]
  passportTokens     VehiclePassportToken[]
  technicians        Technician[]
  checklistItems     ChecklistItem[]
  internalNotes      InternalNote[]
  partsRequests      PartsRequest[]
  laborSessions      LaborSession[]
  communicationTemplates CommunicationTemplate[]
  communicationLogs  CommunicationLog[]
  calendarSyncLogs   CalendarSyncLog[]
  reminderExecutionLogs ReminderExecutionLog[]
}

model WorkshopSettings {
  id                    String   @id @default(cuid())
  workshopId            String   @unique
  workshop              Workshop @relation(fields: [workshopId], references: [id])

  pdfLogoUrl            String?
  publicPortalLogoUrl   String?
  passportLogoUrl       String?
  themeColor            String?
  accentColor           String?

  smsProvider           String   @default("mock")
  smsApiKey             String?
  smsSenderName         String?
  whatsappProvider      String   @default("mock")
  whatsappApiKey        String?
  whatsappPhoneNumber   String?
  emailProvider         String   @default("mock")
  emailApiKey           String?
  emailFromAddress      String?
  emailFromName         String?

  weekdayStart         String   @default("09:00")
  weekdayEnd           String   @default("18:00")
  weekdayWorkingDays   String   @default("1,2,3,4,5")
  weekendStart         String   @default("10:00")
  weekendEnd           String   @default("14:00")
  weekendWorkingDays   String   @default("6")
  holidayEnabled       Boolean  @default(false)
  holidayDates         String?

  defaultAppointmentDuration Int @default(60)
  bufferDuration             Int @default(15)
  reminderTimings             String @default("60,30")

  workOrderTemplate     String?
  servicePassportTemplate String?
  collectionReceiptTemplate String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([workshopId])
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  firstName   String?
  lastName    String?
  workshopId  String
  workshop    Workshop @relation(fields: [workshopId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  auditLogs AuditLog[]
}

model Customer {
  id            String   @id @default(cuid())
  workshopId    String
  workshop      Workshop @relation(fields: [workshopId], references: [id])
  type          CustomerType @default(individual)
  firstName     String?
  lastName      String?
  fullName      String?
  companyName   String?
  contactName   String?
  phone         String
  phone2        String?
  email         String?
  city          String?
  district      String?
  address       String?
  identityNumber String?
  taxNumber     String?
  taxOffice     String?
  notes         String?
  tag           CustomerTag? @default(standard)
  source        CustomerSource?
  priceGroup    CustomerPriceGroup? @default(standard)
  discountRate  Float?     @default(0)
  riskNote      String?
  whatsappConsent Boolean  @default(false)
  smsConsent      Boolean  @default(false)
  emailConsent    Boolean  @default(false)
  kvkkApprovedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vehicles Vehicle[]
  intakes  VehicleIntakeForm[]
  quotes   Quote[]
  appointments Appointment[]
  reminders    MaintenanceReminder[]
  collections  CollectionPayment[]

  @@index([workshopId])
  @@index([workshopId, type])
  @@index([workshopId, phone])
}

enum CustomerType {
  individual
  corporate
}

enum CustomerTag {
  standard
  vip
  risky
  fleet
}

enum CustomerSource {
  referral
  google
  social_media
  walk_in
  existing
  other
}

enum CustomerPriceGroup {
  standard
  discounted
  fleet
}

model Vehicle {
  id           String   @id @default(cuid())
  workshopId   String
  workshop     Workshop @relation(fields: [workshopId], references: [id])
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  plate        String
  brand        String
  model        String
  vehicleType  String?
  modelYear    Int?
  mileage      Int?
  vin          String?
  vinOcrRaw    String?
  vinConfirmed Boolean  @default(false)
  color        String?
  engineNo     String?
  fuelType     String?
  transmission String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  intakes VehicleIntakeForm[]
  quotes  Quote[]
  appointments Appointment[]
  reminders MaintenanceReminder[]
  passportTokens VehiclePassportToken[]

  @@unique([workshopId, plate])
  /// VIN duplicate check is done at application level (not DB unique) because VIN can be null/empty.
  /// Use prisma.vehicle.findFirst({ where: { workshopId, vin } }) for duplicate VIN detection.
  @@index([workshopId])
  @@index([customerId])
  @@index([workshopId, vin])
}

model VehicleIntakeForm {
  id                  String       @id @default(cuid())
  workshopId          String
  workshop            Workshop     @relation(fields: [workshopId], references: [id])
  customerId          String
  customer            Customer     @relation(fields: [customerId], references: [id])
  vehicleId           String
  vehicle             Vehicle      @relation(fields: [vehicleId], references: [id])
  status              IntakeStatus @default(draft)
  mileageAtIntake     Int?
  customerComplaint   String
  internalNote        String?
  approvalTextVersion String?
  approvedAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  photos      VehiclePhoto[]
  damageMarks DamageMark[]
  approvals   ApprovalRequest[]
  shareLinks  PublicShareLink[]
  timelineEvents IntakeTimelineEvent[]
  order       ServiceOrder?

  @@index([workshopId])
  @@index([customerId])
  @@index([vehicleId])
}

enum IntakeStatus {
  draft
  waiting_approval
  approved
  in_progress
  ready_for_delivery
  delivered
  cancelled
}

model VehiclePhoto {
  id              String            @id @default(cuid())
  workshopId      String
  workshop        Workshop          @relation(fields: [workshopId], references: [id])
  intakeFormId    String
  intakeForm      VehicleIntakeForm @relation(fields: [intakeFormId], references: [id])
  serviceOrderId  String?
  serviceOrder    ServiceOrder?     @relation(fields: [serviceOrderId], references: [id])
  type            VehiclePhotoType
  phase           PhotoPhase        @default(intake)
  label           String
  required        Boolean           @default(false)
  fileUrl         String?
  fileName        String?
  mimeType        String?
  sizeBytes       Int?
  storageProvider String?
  storageKey      String?
  note            String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([workshopId])
  @@index([intakeFormId])
  @@index([phase])
  @@index([serviceOrderId])
}

enum VehiclePhotoType {
  front
  rear
  left_side
  right_side
  dashboard_mileage
  registration_front
  registration_back
  vin_area
  damage_detail
  other
}

enum PhotoPhase {
  intake
  repair_progress
  delivery
}

model DamageMark {
  id           String            @id @default(cuid())
  workshopId   String
  workshop     Workshop          @relation(fields: [workshopId], references: [id])
  intakeFormId String
  intakeForm   VehicleIntakeForm @relation(fields: [intakeFormId], references: [id])
  zone         String
  damageType   DamageType
  severity     DamageSeverity
  note         String?
  photoUrl     String?
  createdAt    DateTime          @default(now())

  @@index([workshopId])
  @@index([intakeFormId])
}

enum DamageType {
  scratch
  dent
  broken
  cracked
  paint_damage
  missing_part
  other
}

enum DamageSeverity {
  light
  medium
  heavy
}

model ApprovalRequest {
  id                  String            @id @default(cuid())
  workshopId          String
  workshop            Workshop          @relation(fields: [workshopId], references: [id])
  intakeFormId        String
  intakeForm          VehicleIntakeForm @relation(fields: [intakeFormId], references: [id])
  phone               String
  otpCode             String
  status              ApprovalStatus    @default(pending)
  approvalType        String            @default("vehicle_intake")
  approvalTextVersion String?
  approvedAt          DateTime?
  ipAddress           String?
  userAgent           String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([workshopId])
  @@index([intakeFormId])
}

enum ApprovalStatus {
  pending
  verified
  expired
  cancelled
}

model PublicShareLink {
  id                String            @id @default(cuid())
  workshopId        String
  workshop          Workshop          @relation(fields: [workshopId], references: [id])
  intakeFormId      String
  intakeForm        VehicleIntakeForm @relation(fields: [intakeFormId], references: [id])
  token             String            @unique
  expiresAt         DateTime?
  isActive          Boolean           @default(true)
  showPhotos        Boolean           @default(true)
  showDamage        Boolean           @default(true)
  showOrderItems    Boolean           @default(true)
  showPaymentStatus Boolean           @default(false)
  showTimeline      Boolean           @default(true)
  createdAt         DateTime          @default(now())

  @@index([workshopId])
  @@index([intakeFormId])
}

model IntakeTimelineEvent {
  id           String            @id @default(cuid())
  workshopId   String
  workshop     Workshop          @relation(fields: [workshopId], references: [id])
  intakeFormId String
  intakeForm   VehicleIntakeForm @relation(fields: [intakeFormId], references: [id])
  eventType    String
  description  String
  createdAt    DateTime          @default(now())

  @@index([workshopId])
  @@index([intakeFormId])
  @@index([eventType])
  @@index([createdAt])
}

model Technician {
  id         String          @id @default(cuid())
  workshopId String
  workshop   Workshop        @relation(fields: [workshopId], references: [id])
  fullName   String
  phone      String
  role       TechnicianRole  @default(usta)
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  assignedOrders  ServiceOrder[]
  checklistItems  ChecklistItem[]
  internalNotes   InternalNote[]
  partsRequests   PartsRequest[]
  laborSessions   LaborSession[]

  @@index([workshopId])
  @@index([workshopId, isActive])
  @@index([workshopId, role])
}

enum TechnicianRole {
  usta
  teknisyen
  servis_danismani
  yonetici
}

model ServiceOrder {
  id                   String            @id @default(cuid())
  workshopId           String
  workshop             Workshop          @relation(fields: [workshopId], references: [id])
  intakeFormId         String            @unique
  intakeForm           VehicleIntakeForm @relation(fields: [intakeFormId], references: [id])
  workOrderNo          String?
  status               OrderStatus       @default(draft)
  paymentStatus        PaymentStatus     @default(unpaid)
  technicianName       String?
  assignedTechnicianId String?
  assignedTechnician   Technician?       @relation(fields: [assignedTechnicianId], references: [id])
  assignedAt           DateTime?
  completedAt          DateTime?
  estimatedDeliveryAt  DateTime?
  discountAmount       Float?
  taxRate              Float?
  notes                String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  items ServiceOrderItem[]
  convertedFromQuote       Quote?       @relation("QuoteToServiceOrder")
  convertedFromAppointment Appointment? @relation("AppointmentToServiceOrder")
  collections             CollectionPayment[]
  checklistItems          ChecklistItem[]
  internalNotes           InternalNote[]
  partsRequests           PartsRequest[]
  laborSessions           LaborSession[]
  photos                  VehiclePhoto[]

  paidAmount     Float?
  remainingAmount Float?
  lastPaymentAt  DateTime?

  @@index([workshopId])
  @@index([status])
  @@index([paymentStatus])
  @@index([assignedTechnicianId])
  @@index([workshopId, assignedTechnicianId])
}

enum OrderStatus {
  draft
  waiting_approval
  approved
  in_progress
  waiting_parts
  ready_for_delivery
  delivered
  cancelled
}

enum PaymentStatus {
  unpaid
  partial
  paid
  overpaid
  cancelled
}

enum PaymentMethod {
  cash
  credit_card
  bank_transfer
  other
}

enum CollectionStatus {
  completed
  cancelled
  refunded
}

model CollectionPayment {
  id                String          @id @default(cuid())
  workshopId        String
  workshop          Workshop        @relation(fields: [workshopId], references: [id])
  customerId        String
  customer          Customer        @relation(fields: [customerId], references: [id])
  serviceOrderId    String?
  serviceOrder      ServiceOrder?   @relation(fields: [serviceOrderId], references: [id])
  quoteId           String?
  amount            Float
  currency          String          @default("TRY")
  method            PaymentMethod   @default(cash)
  status            CollectionStatus @default(completed)
  paymentDate       DateTime        @default(now())
  referenceNo       String?
  note              String?
  cancellationReason String?
  createdByUserId   String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([workshopId])
  @@index([customerId])
  @@index([serviceOrderId])
  @@index([paymentDate])
  @@index([method])
  @@index([status])
}

model ServiceOrderItem {
  id             String       @id @default(cuid())
  workshopId     String
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  type           OrderItemType
  name           String
  sku            String?
  unit           String?
  quantity       Int          @default(1)
  unitPrice      Float?
  totalPrice     Float?
  partId         String?
  part           PartStockItem? @relation(fields: [partId], references: [id])
  note           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([workshopId])
  @@index([serviceOrderId])
  @@index([partId])
}

enum OrderItemType {
  part
  labor
}

model Quote {
  id                    String    @id @default(cuid())
  workshopId            String
  workshop              Workshop  @relation(fields: [workshopId], references: [id])
  customerId            String
  customer              Customer  @relation(fields: [customerId], references: [id])
  vehicleId             String?
  vehicle               Vehicle?  @relation(fields: [vehicleId], references: [id])
  quoteNo               String?
  status                QuoteStatus @default(draft)
  title                 String?
  customerRequest       String?
  internalNote          String?
  validUntil            DateTime?
  estimatedLaborTotal   Float?
  estimatedPartsTotal   Float?
  discountAmount        Float?
  taxRate               Float?
  grandTotal            Float?
  convertedServiceOrderId String? @unique
  convertedServiceOrder ServiceOrder? @relation("QuoteToServiceOrder", fields: [convertedServiceOrderId], references: [id])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  items QuoteItem[]

  @@index([workshopId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
}

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
  converted
  cancelled
}

model QuoteItem {
  id        String            @id @default(cuid())
  workshopId String
  workshop  Workshop          @relation(fields: [workshopId], references: [id])
  quoteId   String
  quote     Quote             @relation(fields: [quoteId], references: [id])
  type      QuoteItemType
  name      String
  sku       String?
  unit      String?
  quantity  Int               @default(1)
  unitPrice Float?
  totalPrice Float?
  partId    String?
  part      PartStockItem?    @relation(fields: [partId], references: [id])
  note      String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([workshopId])
  @@index([quoteId])
  @@index([partId])
}

enum QuoteItemType {
  part
  labor
}

model Appointment {
  id                      String             @id @default(cuid())
  workshopId              String
  workshop                Workshop           @relation(fields: [workshopId], references: [id])
  customerId              String
  customer                Customer           @relation(fields: [customerId], references: [id])
  vehicleId               String?
  vehicle                 Vehicle?           @relation(fields: [vehicleId], references: [id])
  appointmentNo           String?
  status                  AppointmentStatus  @default(scheduled)
  appointmentAt           DateTime
  estimatedDurationMinutes Int?
  title                   String?
  customerRequest         String?
  internalNote            String?
  reminderStatus           ReminderStatus    @default(none)
  lastRemindedAt           DateTime?
  convertedServiceOrderId  String?            @unique
  convertedServiceOrder   ServiceOrder?      @relation("AppointmentToServiceOrder", fields: [convertedServiceOrderId], references: [id])
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@index([workshopId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@index([appointmentAt])
}

enum AppointmentStatus {
  scheduled
  confirmed
  arrived
  converted
  completed
  cancelled
  no_show
}

enum ReminderStatus {
  none
  pending
  sent
  failed
}

enum MaintenanceReminderStatus {
  upcoming
  due_soon
  overdue
  completed
  postponed
  cancelled
}

enum MaintenanceReminderType {
  periodic_maintenance
  oil_change
  inspection
  tire_change
  brake_check
  battery_check
  insurance
  other
}

enum MaintenanceChannel {
  none
  sms
  whatsapp
  phone
  email
}

model MaintenanceReminder {
  id                  String                     @id @default(cuid())
  workshopId          String
  workshop            Workshop                   @relation(fields: [workshopId], references: [id])
  customerId          String
  customer            Customer                   @relation(fields: [customerId], references: [id])
  vehicleId           String
  vehicle             Vehicle                    @relation(fields: [vehicleId], references: [id])
  title               String
  type                MaintenanceReminderType    @default(other)
  status              MaintenanceReminderStatus  @default(upcoming)
  dueDate             DateTime?
  dueMileage          Int?
  currentMileage      Int?
  lastServiceDate     DateTime?
  lastServiceMileage  Int?
  reminderDaysBefore  Int?
  reminderKmBefore    Int?
  preferredChannel    MaintenanceChannel         @default(none)
  reminderStatus      ReminderStatus             @default(none)
  lastRemindedAt      DateTime?
  customerNote        String?
  internalNote        String?
  completedAt         DateTime?
  completedServiceOrderId String?                @unique
  createdAppointmentId    String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([workshopId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([status])
  @@index([dueDate])
  @@index([dueMileage])
}

model PartStockItem {
  id               String   @id @default(cuid())
  workshopId       String
  workshop         Workshop @relation(fields: [workshopId], references: [id])
  name             String
  sku              String?
  oemNo            String?
  brand            String?
  category         String?
  description      String?
  unit             String   @default("adet")
  stockQty         Int      @default(0)
  criticalStockQty Int      @default(0)
  purchasePrice    Float?
  salePrice        Float?
  currency         String   @default("TRY")
  supplierName     String?
  supplierPhone    String?
  supplierId       String?
  supplier         Supplier? @relation(fields: [supplierId], references: [id])
  shelfLocation    String?
  barcode          String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  movements        StockMovement[]
  serviceOrderItems ServiceOrderItem[]
  quoteItems        QuoteItem[]

  @@index([workshopId])
  @@index([name])
  @@index([sku])
  @@index([oemNo])
  @@index([brand])
  @@index([category])
  @@index([stockQty])
  @@index([isActive])
  @@index([supplierId])
}

model StockMovement {
  id           String   @id @default(cuid())
  workshopId   String
  workshop     Workshop @relation(fields: [workshopId], references: [id])
  partId       String
  part         PartStockItem @relation(fields: [partId], references: [id])
  type         String
  quantity     Int
  previousQty  Int?
  newQty       Int?
  reason       String?
  sourceType   String?
  sourceId     String?
  createdByUserId String?
  createdAt    DateTime @default(now())

  @@index([workshopId])
  @@index([partId])
  @@index([type])
  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  workshopId   String
  workshop     Workshop @relation(fields: [workshopId], references: [id])
  actorUserId  String?
  actorUser    User?    @relation(fields: [actorUserId], references: [id])
  entityType   String
  entityId     String
  action       String
  metadataJson String?
  createdAt    DateTime @default(now())

  @@index([workshopId])
}

model Supplier {
  id                   String   @id @default(cuid())
  workshopId           String
  workshop             Workshop @relation(fields: [workshopId], references: [id])
  name                 String
  contactPerson        String?
  phone                String?
  phone2               String?
  email                String?
  website              String?
  city                 String?
  address              String?
  taxNumber            String?
  taxOffice            String?
  category             String?
  paymentTermDays      Int?
  averageDeliveryDays  Int?
  performanceNote      String?
  internalNote         String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  parts PartStockItem[]

  @@index([workshopId])
  @@index([name])
  @@index([phone])
  @@index([email])
  @@index([city])
  @@index([isActive])
}

model VehiclePassportToken {
  id                    String    @id @default(cuid())
  workshopId            String
  workshop              Workshop  @relation(fields: [workshopId], references: [id])
  vehicleId             String
  vehicle               Vehicle   @relation(fields: [vehicleId], references: [id])
  token                 String    @unique
  label                 String?
  isActive              Boolean   @default(true)
  expiresAt             DateTime?
  showServiceHistory    Boolean   @default(true)
  showWorkOrders        Boolean   @default(true)
  showDamages           Boolean   @default(true)
  showPhotos            Boolean   @default(true)
  showReminders         Boolean   @default(true)
  showPaymentStatus     Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([workshopId])
  @@index([vehicleId])
  @@index([token])
}

model OcrLog {
  id             String   @id @default(cuid())
  workshopId     String
  workshop       Workshop @relation(fields: [workshopId], references: [id])
  /// OCR provider name: "mock", "deepseek", "openai", or "tesseract"
  ocrProvider    String
  /// Raw OCR text — sensitive, never exposed via public API
  rawText        String?
  /// JSON of extracted fields before user confirmation
  extractedJson  String?
  /// JSON of user-confirmed fields
  confirmedJson  String?
  confirmedAt    DateTime?
  userId         String?
  customerId     String?
  vehicleId      String?
  serviceOrderId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([workshopId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([serviceOrderId])
}

model ChecklistItem {
  id              String          @id @default(cuid())
  workshopId      String
  workshop        Workshop        @relation(fields: [workshopId], references: [id])
  serviceOrderId  String
  serviceOrder    ServiceOrder    @relation(fields: [serviceOrderId], references: [id])
  category        ChecklistCategory @default(inspection)
  description     String
  isCompleted     Boolean         @default(false)
  completedById   String?
  completedBy     Technician?     @relation(fields: [completedById], references: [id])
  completedAt     DateTime?
  note            String?
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([workshopId])
  @@index([serviceOrderId])
  @@index([category])
  @@index([isCompleted])
}

enum ChecklistCategory {
  inspection
  repair
  delivery
}

model InternalNote {
  id              String        @id @default(cuid())
  workshopId      String
  workshop        Workshop      @relation(fields: [workshopId], references: [id])
  serviceOrderId  String
  serviceOrder    ServiceOrder  @relation(fields: [serviceOrderId], references: [id])
  authorId        String?
  author          Technician?   @relation(fields: [authorId], references: [id])
  content         String
  isPinned        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([workshopId])
  @@index([serviceOrderId])
  @@index([authorId])
  @@index([createdAt])
}

model PartsRequest {
  id              String            @id @default(cuid())
  workshopId      String
  workshop        Workshop          @relation(fields: [workshopId], references: [id])
  serviceOrderId  String
  serviceOrder    ServiceOrder     @relation(fields: [serviceOrderId], references: [id])
  requestedById   String?
  requestedBy     Technician?      @relation(fields: [requestedById], references: [id])
  partName        String
  partSku         String?
  quantity        Int               @default(1)
  note            String?
  status          PartsRequestStatus @default(requested)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([workshopId])
  @@index([serviceOrderId])
  @@index([status])
  @@index([requestedById])
}

enum PartsRequestStatus {
  requested
  prepared
  delivered
}

model LaborSession {
  id              String        @id @default(cuid())
  workshopId      String
  workshop        Workshop      @relation(fields: [workshopId], references: [id])
  serviceOrderId  String
  serviceOrder    ServiceOrder  @relation(fields: [serviceOrderId], references: [id])
  technicianId    String?
  technician      Technician?   @relation(fields: [technicianId], references: [id])
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([workshopId])
  @@index([serviceOrderId])
  @@index([technicianId])
}

enum CommunicationType {
  sms
  whatsapp
  email
}

model CommunicationTemplate {
  id          String             @id @default(cuid())
  workshopId  String
  workshop    Workshop           @relation(fields: [workshopId], references: [id])
  templateKey String
  channel     CommunicationType
  content     String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([workshopId, templateKey, channel])
  @@index([workshopId])
  @@index([templateKey])
  @@index([channel])
}

enum CalendarEventType {
  appointment
  delivery
  maintenance_reminder
}

model CalendarSyncLog {
  id              String   @id @default(cuid())
  workshopId      String
  workshop        Workshop @relation(fields: [workshopId], references: [id])
  provider        String
  direction       String   @default("outbound")
  status          String   @default("pending")
  eventType       String?
  entityId        String?
  externalEventId String?
  errorMessage    String?
  syncedAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([workshopId])
  @@index([provider])
  @@index([status])
  @@index([syncedAt])
}

model ReminderExecutionLog {
  id              String   @id @default(cuid())
  workshopId      String
  workshop        Workshop @relation(fields: [workshopId], references: [id])
  jobType         String
  entityType      String?
  entityId        String?
  status          String   @default("pending")
  processedCount  Int      @default(0)
  sentCount       Int      @default(0)
  failedCount     Int      @default(0)
  errorMessage    String?
  executedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([workshopId])
  @@index([jobType])
  @@index([status])
  @@index([executedAt])
}

model CommunicationLog {
  id           String             @id @default(cuid())
  workshopId   String
  workshop     Workshop           @relation(fields: [workshopId], references: [id])
  type         CommunicationType
  provider     String
  recipient    String
  status       String              @default("pending")
  templateKey  String?
  entityType   String?
  entityId     String?
  providerId   String?
  errorMessage String?
  sentAt       DateTime           @default(now())
  createdAt    DateTime           @default(now())

  @@index([workshopId])
  @@index([type])
  @@index([status])
  @@index([templateKey])
  @@index([entityType, entityId])
  @@index([sentAt])
}